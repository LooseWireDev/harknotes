{
  "productName": "harknotes",
  "version": "0.0.0",
  "identifier": "com.harknotes.app",
  "build": {
    "beforeDevCommand": "cd ../web && pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../web && pnpm build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Harknotes",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost http://localhost:* http://127.0.0.1:* https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Local-first meeting notes with on-device transcription"
  }
}
